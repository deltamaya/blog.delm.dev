---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllBlogsMeta } from "../../lib/blogs";

const allBlogs = getAllBlogsMeta().map((b) => ({
  slug: b.slug,
  title: b.title,
  date: b.date.toLocaleDateString("en", {
    year: "numeric",
    month: "short",
    day: "numeric",
  }),
  tags: b.tags,
  ai: b.ai ?? false,
}));
---

<BaseLayout title="Search">
  <div class="flex flex-grow flex-col items-center">
    <div class="w-full max-w-[48rem] px-4 py-10 flex flex-col gap-8">
      <!-- Page header -->
      <div class="border-b border-neutral-200 dark:border-neutral-800 pb-6">
        <h1 class="text-4xl font-black tracking-tight">
          <span class="text-red-600">S</span>earch
        </h1>
      </div>

      <!-- Search input -->
      <div class="flex items-stretch gap-0">
        <input
          id="search-input"
          type="text"
          placeholder="Search titles and tags…"
          autocomplete="off"
          spellcheck="false"
          class="flex-1 border border-neutral-300 dark:border-neutral-700 bg-transparent px-4 py-2.5 text-sm font-sans text-neutral-900 dark:text-white placeholder-neutral-400 dark:placeholder-neutral-600 focus:outline-none focus:border-neutral-900 dark:focus:border-neutral-100 transition-colors duration-150"
        />
        <button
          id="search-btn"
          aria-label="Search"
          class="flex items-center justify-center px-4 py-2.5 border border-l-0 border-neutral-300 dark:border-neutral-700 text-neutral-500 dark:text-neutral-400 hover:border-red-500 hover:text-red-500 transition-colors duration-150"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path
              d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5A6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5S14 7.01 14 9.5S11.99 14 9.5 14z"
            ></path>
          </svg>
        </button>
      </div>

      <!-- Results area -->
      <div id="results" class="flex flex-col gap-2">
        <!-- Default: show all -->
        <div
          id="results-list"
          class="flex flex-col divide-y divide-neutral-100 dark:divide-neutral-800/60"
        >
        </div>
        <div
          id="results-empty"
          class="hidden py-12 text-center font-mono text-sm text-neutral-400 dark:text-neutral-600 tracking-wider uppercase"
        >
          No results found
        </div>
        <div
          id="results-hint"
          class="py-4 font-mono text-[11px] text-neutral-400 dark:text-neutral-600"
        >
          Showing all {allBlogs.length} posts — type to filter
        </div>
      </div>

      <!-- Google fallback -->
      <div
        class="pt-2 border-t border-neutral-200 dark:border-neutral-800 flex items-center justify-between"
      >
        <span
          class="font-mono text-[11px] text-neutral-400 dark:text-neutral-600"
        >
          Not finding it?
        </span>
        <button
          id="google-btn"
          class="flex items-center gap-1.5 font-mono text-[10px] tracking-widest uppercase px-3 py-1.5 border border-neutral-300 dark:border-neutral-700 text-neutral-500 dark:text-neutral-400 hover:border-red-500 hover:text-red-500 transition-colors duration-150"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="11"
            height="11"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path
              d="M21 13v10h-21v-19h12v2h-10v15h17v-8h2zm3-12h-10.988l4.035 4-6.977 7.07 2.828 2.828 6.977-7.07 4.125 4.172v-11z"
            ></path>
          </svg>
          Search on Google
        </button>
      </div>
    </div>
  </div>

  <script define:vars={{ allBlogs }}>
    const input = document.getElementById("search-input");
    const btn = document.getElementById("search-btn");
    const googleBtn = document.getElementById("google-btn");
    const resultsList = document.getElementById("results-list");
    const resultsEmpty = document.getElementById("results-empty");
    const resultsHint = document.getElementById("results-hint");

    function renderPost(blog, keyword) {
      const kw = keyword.toLowerCase();
      // Highlight matched part in title
      let titleHtml = blog.title;
      if (kw) {
        const idx = blog.title.toLowerCase().indexOf(kw);
        if (idx !== -1) {
          titleHtml =
            blog.title.slice(0, idx) +
            `<mark class="bg-yellow-200 dark:bg-yellow-800 text-inherit rounded-sm px-0.5">${blog.title.slice(idx, idx + kw.length)}</mark>` +
            blog.title.slice(idx + kw.length);
        }
      }

      const tagsHtml = blog.tags
        .map(
          (t) =>
            `<span class="font-mono text-xs text-neutral-400 dark:text-neutral-600 uppercase">#${t}</span>`,
        )
        .join("");

      const aiHtml = "";

      return `
        <a href="/blog/${blog.slug}"
          class="group flex items-center gap-4 py-3 -mx-2 px-2 hover:bg-neutral-50 dark:hover:bg-neutral-800/40 transition-colors duration-150">
          <span class="font-mono text-[11px] text-neutral-400 dark:text-neutral-600 shrink-0 tabular-nums">${blog.date}</span>
          <span class="flex-1 text-sm group-hover:text-red-600 transition-colors duration-150 leading-snug">${titleHtml}</span>
          <div class="flex items-center gap-1.5 shrink-0 hidden sm:flex">${tagsHtml}</div>
        </a>`;
    }

    function doFilter() {
      const kw = input.value.trim().toLowerCase();
      const filtered = kw
        ? allBlogs.filter(
            (b) =>
              b.title.toLowerCase().includes(kw) ||
              b.tags.some((t) => t.includes(kw)),
          )
        : allBlogs;

      if (filtered.length === 0) {
        resultsList.innerHTML = "";
        resultsEmpty.classList.remove("hidden");
        resultsHint.classList.add("hidden");
      } else {
        resultsEmpty.classList.add("hidden");
        resultsList.innerHTML = filtered.map((b) => renderPost(b, kw)).join("");
        resultsHint.innerHTML = kw
          ? `${filtered.length} result${filtered.length === 1 ? "" : "s"} for "<strong>${input.value.trim()}</strong>"`
          : `Showing all ${allBlogs.length} posts — type to filter`;
        resultsHint.classList.remove("hidden");
      }
    }

    function doGoogleSearch() {
      const kw = input.value.trim();
      const q = (kw || "").split(" ").filter(Boolean).join("+");
      window.open(
        `https://www.google.com/search?q=site:blog.delm.dev${q ? "+" + q : ""}`,
        "_blank",
      );
    }

    input.addEventListener("input", doFilter);
    input.addEventListener("keydown", (e) => {
      if (e.key === "Enter") doGoogleSearch();
    });
    btn.addEventListener("click", doGoogleSearch);
    googleBtn.addEventListener("click", doGoogleSearch);

    // Initial render
    doFilter();
  </script>
</BaseLayout>
