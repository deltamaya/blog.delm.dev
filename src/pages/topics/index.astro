---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getTagCounts } from "../../lib/blogs";

const tagCounts = getTagCounts();
const total = tagCounts.reduce((s, [, c]) => s + c, 0);
const maxCount = Math.max(...tagCounts.map(([, c]) => c));
---

<BaseLayout title="Topics">
  <div class="flex flex-grow flex-col items-center">
    <div class="w-full max-w-[48rem] px-4 py-10 flex flex-col gap-8">
      <!-- Page header -->
      <div
        class="flex flex-col gap-1 border-b border-neutral-200 dark:border-neutral-800 pb-6"
      >
        <h1 class="text-4xl font-black tracking-tight">
          <span class="text-red-600">T</span>opics
        </h1>
        <p class="font-mono text-[11px] text-neutral-400 dark:text-neutral-600">
          {tagCounts.length} tags · {total} posts
        </p>
      </div>

      <!-- Tag grid -->
      <div class="flex flex-wrap gap-2">
        {
          tagCounts.map(([tag, count]) => {
            const weight = count / maxCount;
            return (
              <a
                href={`/topics/${tag.toLowerCase()}`}
                class="group flex items-center gap-1.5 px-3 py-1.5 border border-neutral-200 dark:border-neutral-800 hover:border-red-500 hover:text-red-600 dark:hover:border-red-500 dark:hover:text-red-500 transition-colors duration-150"
              >
                <span
                  class={`font-mono uppercase tracking-wider transition-colors ${weight >= 0.6 ? "text-sm font-bold" : weight >= 0.3 ? "text-xs font-semibold" : "text-xs"}`}
                >
                  {tag}
                </span>
                <span class="font-mono text-[10px] text-neutral-400 dark:text-neutral-600 group-hover:text-red-400 transition-colors">
                  {count}
                </span>
              </a>
            );
          })
        }
      </div>
    </div>
  </div>
</BaseLayout>
