---
import fs from "node:fs";
import path from "node:path";
import matter from "gray-matter";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllSlugs } from "../../lib/blogs";
import { renderMarkdown } from "../../lib/markdown";
import type { Heading } from "../../lib/markdown";
import { authorLinks } from "../../lib/authors";

export async function getStaticPaths() {
  return getAllSlugs().map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const filePath = path.resolve(`content/${slug}.md`);
const raw = fs.readFileSync(filePath, "utf-8");
const { data: metadata, content: rawContent } = matter(raw);
const { html, headings } = renderMarkdown(rawContent);
const postDate = new Date(metadata.date);
const now = new Date();
const ageMs = now.getTime() - postDate.getTime();
const sixMonthsMs = 6 * 30 * 24 * 60 * 60 * 1000;
const twelveMonthsMs = 12 * 30 * 24 * 60 * 60 * 1000;
const isOutdated = ageMs > twelveMonthsMs;
const isMaybeStale = !isOutdated && ageMs > sixMonthsMs;

type AILevel = {
  level: 1 | 2 | 3;
  label: string;
  desc: string;
  border: string;
  bg: string;
  dot: string;
  text: string;
};
const aiLevels: Record<string, AILevel> = {
  assisted: {
    level: 1,
    label: "AI Assisted",
    desc: "Portions of this article were written, restructured or translated with AI assistance. The author has reviewed and edited the content, but it may contain AI-generated phrasing or ideas.",
    border: "border-neutral-300 dark:border-neutral-700",
    bg: "bg-neutral-50 dark:bg-neutral-950/30",
    dot: "bg-neutral-400",
    text: "text-neutral-600 dark:text-neutral-400",
  },

  generated: {
    level: 2,
    label: "AI Generated",
    desc: "The majority of this article was generated by AI, and supervised by the author. While the author has reviewed and edited the content, it may contain AI-generated phrasing or ideas.",
    border: "border-amber-300 dark:border-amber-700",
    bg: "bg-amber-50 dark:bg-amber-950/30",
    dot: "bg-amber-400",
    text: "text-amber-600 dark:text-amber-400",
  },
};
const _aiRaw = metadata.ai;
const _aiKey =
  !_aiRaw || _aiRaw === false || _aiRaw === "false"
    ? null
    : _aiRaw === true || _aiRaw === "True" || _aiRaw === "true"
      ? "translated"
      : String(_aiRaw).toLowerCase();
const aiInfo = _aiKey ? (aiLevels[_aiKey] ?? null) : null;

type Disclaimer = { icon: string; label: string; desc: string };
const disclaimerDefs: Record<string, Disclaimer> = {
  financial: {
    icon: "M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z",
    label: "Not Financial Advice",
    desc: "Nothing in this article constitutes financial, investment, or trading advice. All content is for informational purposes only. Always do your own research and consult a qualified financial advisor before making any investment decisions.",
  },
  medical: {
    icon: "M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z",
    label: "Not Medical Advice",
    desc: "The information in this article is for general informational purposes only and is not a substitute for professional medical advice, diagnosis, or treatment. Always consult a qualified healthcare provider with any questions you may have.",
  },
  legal: {
    icon: "M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z",
    label: "Not Legal Advice",
    desc: "Nothing in this article constitutes legal advice. The content is provided for informational purposes only. For advice on your specific situation, please consult a qualified legal professional.",
  },
};
const _disclaimerRaw = metadata.disclaimer;
const disclaimerKeys: string[] = !_disclaimerRaw
  ? []
  : Array.isArray(_disclaimerRaw)
    ? _disclaimerRaw.map((d: string) => d.toLowerCase())
    : [String(_disclaimerRaw).toLowerCase()];
const disclaimers = disclaimerKeys
  .map((k: string) => disclaimerDefs[k])
  .filter(Boolean);
---

<BaseLayout title={metadata.title}>
  <div class="flex w-full flex-col flex-wrap items-center">
    <div class="flex h-full w-full max-w-[800px] flex-col p-4 dark:text-white">
      <div class="flex flex-wrap items-start">
        <h1 class="font-serif text-3xl font-bold lg:text-5xl leading-tight">
          {metadata.title}
        </h1>
        <a
          href="https://github.com/deltamaya/blog.delm.dev/issues/new"
          class="flex items-center gap-1 text-xs text-gray-500 hover:text-red-500 hover:underline dark:text-gray-300 lg:text-sm"
        >
          <svg
            fill="none"
            shape-rendering="geometricPrecision"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2.5"
            viewBox="0 0 24 24"
            height="12"
            width="12"
          >
            <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"
            ></path>
            <path d="M15 3h6v6"></path>
            <path d="M10 14L21 3"></path>
          </svg>
          Suggest Changes
        </a>
      </div>

      <div class="my-1 flex text-base text-gray-500 dark:text-gray-300">
        {postDate.toLocaleDateString("en")}
        &nbsp;·&nbsp; Authored by&nbsp;
        <div class="flex space-x-2">
          {
            (metadata.authors ?? []).map((author: string, i: number) => {
              const href = authorLinks[author.toLowerCase()];
              return (
                <span>
                  {href ? (
                    <a
                      href={href}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="hover:text-red-500 hover:underline"
                    >
                      {author}
                    </a>
                  ) : (
                    <span>{author}</span>
                  )}
                  {i !== (metadata.authors ?? []).length - 1 ? "," : ""}
                </span>
              );
            })
          }
        </div>
      </div>

      <div class="flex flex-wrap text-lg font-bold text-red-500">
        {
          (metadata.tags ?? []).map((tag: string) => (
            <a
              href={`/topics/${tag.toLowerCase()}`}
              class="mr-5 hover:underline"
            >
              #{tag.toUpperCase()}
            </a>
          ))
        }
      </div>

      {
        aiInfo && (
          <div
            class={`mt-4 w-full border ${aiInfo.border} ${aiInfo.bg} px-4 py-3 transition-colors`}
          >
            <div class="flex items-center justify-between gap-4">
              <div class="flex items-center gap-2">
                <span
                  class={`font-mono text-xs tracking-widest uppercase font-bold ${aiInfo.text}`}
                >
                  {aiInfo.label}
                </span>
              </div>
              <div class="flex items-center gap-1 flex-shrink-0">
                {[1, 2, 3].map((i) => (
                  <span
                    class={`w-2 h-2 rounded-full ${i <= aiInfo.level ? aiInfo.dot : "bg-neutral-200 dark:bg-neutral-700"}`}
                  />
                ))}
              </div>
            </div>
            <p class="mt-1.5 text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">
              {aiInfo.desc}
            </p>
          </div>
        )
      }

      {
        disclaimers.map((d) => (
          <div class="mt-3 flex gap-3 w-full border border-red-200 dark:border-red-900 bg-red-50 dark:bg-red-950/30 px-4 py-3 transition-colors">
            <svg
              class="flex-shrink-0 mt-0.5 text-red-500"
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path d={d.icon} />
            </svg>
            <div class="flex flex-col gap-0.5">
              <span class="font-mono text-xs tracking-widest uppercase text-red-600 dark:text-red-400 font-semibold">
                {d.label}
              </span>
              <p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">
                {d.desc}
              </p>
            </div>
          </div>
        ))
      }

      {
        isMaybeStale && (
          <div class="mt-3 flex gap-3 w-full border border-neutral-300 dark:border-neutral-700 bg-neutral-50 dark:bg-neutral-900/20 px-4 py-3 transition-colors">
            <svg
              class="flex-shrink-0 mt-0.5 text-neutral-400 dark:text-neutral-500"
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zm4.24 16L12 15.45 7.77 18l1.12-4.81-3.73-3.23 4.92-.42L12 5l1.92 4.53 4.92.42-3.73 3.23L16.23 18z" />
            </svg>
            <div class="flex flex-col gap-0.5">
              <span class="font-mono text-xs tracking-widest uppercase text-neutral-500 dark:text-neutral-400 font-semibold">
                Potentially Stale
              </span>
              <p class="text-sm text-neutral-500 dark:text-neutral-500 leading-relaxed">
                This article is over 6 months old. Some details may have changed
                since it was written.
              </p>
            </div>
          </div>
        )
      }

      {
        isOutdated && (
          <div class="mt-3 flex gap-3 w-full border border-yellow-300 dark:border-yellow-700 bg-yellow-50 dark:bg-yellow-950/30 px-4 py-3 transition-colors">
            <svg
              class="flex-shrink-0 mt-0.5 text-yellow-500"
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path d="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z" />
            </svg>
            <div class="flex flex-col gap-0.5">
              <span class="font-mono text-xs tracking-widest uppercase text-yellow-600 dark:text-yellow-400 font-semibold">
                Outdated Content
              </span>
              <p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">
                This article was published more than 12 months ago. Some
                information, data, opinions or references may be outdated,
                inaccurate or no longer applicable due to time changes. Please
                double-check the latest relevant information before reference or
                use.
              </p>
            </div>
          </div>
        )
      }

      {
        headings.length > 0 && (
          <nav
            id="toc"
            class="mt-6 w-full border border-neutral-300 dark:border-neutral-700 transition-colors"
          >
            <button
              class="flex w-full justify-between items-center px-4 py-3 cursor-pointer hover:bg-neutral-50 dark:hover:bg-neutral-800/50 transition-colors"
              id="toc-toggle"
              aria-label="Toggle table of contents"
            >
              <span class="font-mono font-bold text-xs tracking-widest uppercase text-neutral-500 dark:text-neutral-400">
                Table of Contents
              </span>
              <svg
                id="toc-icon"
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                class="fill-neutral-400 dark:fill-neutral-600 transition-transform duration-200 rotate-180"
              >
                <path d="M7.41 8.58L12 13.17l4.59-4.59L18 10l-6 6l-6-6z" />
              </svg>
            </button>
            <div
              id="toc-list"
              class="grid transition-[grid-template-rows] duration-300 ease-in-out border-t border-neutral-300 dark:border-neutral-700"
              style="grid-template-rows: 1fr;"
            >
              <div class="overflow-hidden">
                <div class="flex flex-col py-3 px-4 gap-0.5">
                  {headings.map((h: Heading) => (
                    <a
                      class="text-sm text-neutral-500 dark:text-neutral-400 hover:text-red-600 dark:hover:text-red-500 transition-colors duration-150 leading-relaxed"
                      style={`padding-left: ${(h.depth - 1) * 14}px`}
                      href={`#${h.id}`}
                    >
                      {h.depth === 2 && (
                        <span class="text-neutral-300 dark:text-neutral-700 mr-1.5 font-mono text-[11px]">
                          —
                        </span>
                      )}
                      {h.depth >= 3 && (
                        <span class="text-neutral-300 dark:text-neutral-700 mr-1.5 font-mono text-[11px]">
                          ·
                        </span>
                      )}
                      {h.text}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          </nav>
        )
      }

      <hr
        class="my-10 h-[1px] transition-colors border-neutral-200 dark:border-neutral-800"
      />

      <article
        class="font-serif prose prose-lg prose-neutral w-full max-w-[800px] self-center dark:prose-invert prose-h1:my-5 prose-h1:text-3xl prose-h2:my-4 prose-h2:text-2xl prose-h3:my-4 prose-h3:text-xl prose-h4:my-4 prose-h4:text-xl prose-p:my-4"
        set:html={html}
      />
    </div>
  </div>

  <button
    id="return-top"
    aria-label="Return to top"
    class="fixed bottom-8 right-8 z-50 bg-neutral-900 dark:bg-neutral-100 text-white dark:text-neutral-900 p-2 shadow-lg hover:bg-red-600 dark:hover:bg-red-600 dark:hover:text-white cursor-pointer transition-[transform,opacity] duration-300 ease-in-out opacity-0 translate-y-4 pointer-events-none"
    onclick="window.scrollTo({top:0,behavior:'smooth'})"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="currentColor"
    >
      <path d="M7.41 15.41L12 10.83l4.59 4.58L18 14l-6-6-6 6z"></path>
    </svg>
  </button>

  <script>
    document.querySelectorAll(".copy-button").forEach((btn) => {
      btn.textContent = "Copy";
      btn.addEventListener("click", () => {
        const code =
          (btn as HTMLElement).previousElementSibling?.textContent ?? "";
        navigator.clipboard.writeText(code).then(() => {
          btn.textContent = "Copied";
          (btn as HTMLButtonElement).disabled = true;
          setTimeout(() => {
            btn.textContent = "Copy";
            (btn as HTMLButtonElement).disabled = false;
          }, 3000);
        });
      });
    });
    const returnBtn = document.getElementById("return-top");
    window.addEventListener("scroll", () => {
      if (!returnBtn) return;
      if (window.scrollY >= 500) {
        returnBtn.classList.remove("opacity-0", "pointer-events-none");
        returnBtn.classList.add("opacity-100", "pointer-events-auto");
      } else {
        returnBtn.classList.add("opacity-0", "pointer-events-none");
        returnBtn.classList.remove("opacity-100", "pointer-events-auto");
      }
    });
    const tocToggle = document.getElementById("toc-toggle");
    const tocList = document.getElementById("toc-list") as HTMLElement | null;
    const tocIcon = document.getElementById("toc-icon");
    let tocOpen = true;
    tocToggle?.addEventListener("click", () => {
      tocOpen = !tocOpen;
      if (tocList) {
        tocList.style.gridTemplateRows = tocOpen ? "1fr" : "0fr";
      }
      tocIcon?.classList.toggle("rotate-180");
    });
  </script>
</BaseLayout>
